# Copy to datasuite/.env.deploy (gitignored)
#
# Infomaniak → exosites.ch → FTP / SSH → user scoped to datasuite (Apache | PHP)
# Replace YOUR_IK_ID with your Infomaniak account id prefix.

FTP_HOST=YOUR_IK_ID.ftp.infomaniak.com
FTP_USER=YOUR_IK_ID_datasuite_ro
FTP_PASSWORD=

REMOTE_PATH=sites/datasuite.exosites.ch

# UPLOAD_ENV=1
# VERIFY_AFTER_DEPLOY=1
