# Runtime (on Infomaniak — set in Manager → api.exosites.ch → Node.js → variables)
PORT=3000
NODE_ENV=production

# MariaDB (Infomaniak → Bases de données). Single database for accounts + crash reports.
DB_HOST=your-db.myd.infomaniak.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_exo_app_db

# JWT — generate: openssl rand -base64 48
JWT_SECRET=change-me-in-production
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30

# Free trial length (days) — matches desktop entitlement gate
FREE_TRIAL_DAYS=30

# Crash ingest — shared secret the desktop app sends in X-Crash-Token.
# Generate: openssl rand -hex 32. Empty disables POST /v1/crash-reports.
CRASH_INGEST_TOKEN=change-me-crash-token

# ─── Social sign-in (optional) ───────────────────────────────────────────────
# Public base URL of this API. Used to build OAuth redirect URIs and the
# /auth/done handoff page. Must match what providers are configured with.
APP_BASE_URL=https://api.exosites.ch

# Signs the short-lived OAuth `state` JWT. Falls back to JWT_SECRET if unset.
# Generate: openssl rand -base64 48
AUTH_STATE_SECRET=
# Lifetime (seconds) of the one-time code the desktop trades for a session.
AUTH_EXCHANGE_CODE_TTL=120

# Google — Google Cloud Console → Credentials → OAuth client (Web application).
# Authorized redirect URI: https://api.exosites.ch/auth/google/callback
# Leave blank to hide the Google button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=  # defaults to ${APP_BASE_URL}/auth/google/callback

# Apple — Apple Developer → Identifiers → Services ID + Sign in with Apple key.
# APPLE_CLIENT_ID is the Services ID (e.g. ch.exosites.signin), NOT the app bundle id.
# Return URL: https://api.exosites.ch/auth/apple/callback
# APPLE_PRIVATE_KEY is the .p8 contents; newlines may be written as literal \n.
# Leave blank to hide the Apple button.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# APPLE_REDIRECT_URI=  # defaults to ${APP_BASE_URL}/auth/apple/callback

# ─── Cloud sort LLM (server-provisioned desktop credentials) ────────────────
# Public LiteLLM gateway URL returned to entitled desktop clients.
SORT_LLM_BASE_URL=https://llm-staging.exosites.ch
# Server-only master key — never returned to clients unless delegation is enabled.
LITELLM_MASTER_KEY=
# Short-lived virtual key lifetime (seconds). Default 24h.
SORT_LLM_TOKEN_TTL_SECONDS=86400
# Comma-separated models the issued key may call.
SORT_LLM_MODELS=mistral,nomic-embed-text,moondream
SORT_LLM_MAX_PARALLEL=2
# Per-user parallel analyze rows when cloud credentials sync (default 1 = fair multi-tenant).
SORT_CLOUD_SORT_CONCURRENCY=2
# Route classify/embed through Redis fair queue (set 1 when VPS queue overlay is live).
SORT_LLM_QUEUE_ENABLED=1
# auto = direct when idle; queue_url in credentials only when pending_jobs >= threshold
SORT_LLM_QUEUE_IN_CREDENTIALS=auto
SORT_QUEUE_ADMIT_THRESHOLD=2
SORT_QUEUE_WORKERS=4
# Staging-only fallback when LiteLLM /key/generate is unavailable (not for production GA).
SORT_LLM_ALLOW_MASTER_DELEGATION=0
# Comma-separated browser origins allowed for CORS (defaults: exosites.ch).
# Apple/Google OAuth callbacks are always allowed (appleid.apple.com, accounts.google.com, …).
# CORS_ALLOWED_ORIGINS=https://exosites.ch,https://www.exosites.ch
# Local/tests: skip LiteLLM and return this fixed bearer token.
# SORT_LLM_MOCK_TOKEN=dev-sort-token

# ─── WhatsApp Business webhooks (optional) ───────────────────────────────────
# Meta App Secret from developers.facebook.com → App → Settings → Basic
WHATSAPP_APP_SECRET=
# Verify token you enter in Meta → WhatsApp → Configuration → Webhook
WHATSAPP_VERIFY_TOKEN=
# How long inbound/delivery events are kept per account (days)
WHATSAPP_EVENT_RETENTION_DAYS=30

# Meta Embedded Signup (optional — enables one-click Business connect in desktop app)
# Public App ID from Meta → Settings → Basic
META_APP_ID=
# App secret — server only; never ship to desktop builds
META_APP_SECRET=
# Embedded Signup configuration ID from Meta → WhatsApp → Embedded Signup
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=
