# Copy to `.env` for local Vite builds. For production installers, set these in CI secrets
# or your packaging env so they are baked at `npm run build` time.

# Browser / static demo: full URL of the FastAPI backend (default is `DEFAULT_API_BASE` in src/constants.ts).
# If you point at another host/port, add that origin to `connect-src` in frontend/index.html (CSP meta) so fetches are allowed.
# VITE_API_BASE=http://127.0.0.1:7799

# Public privacy / terms for EXO (hosted on exosites.ch). Shown in Settings → Welcome.
# French locale pages: /fr/app-privacy and /fr/app-terms
VITE_PRIVACY_POLICY_URL=https://exosites.ch/eng/app-privacy
VITE_TERMS_OF_SERVICE_URL=https://exosites.ch/eng/app-terms

# Sentry DSN for optional crash reporting (users must still opt in under Settings → Privacy)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# External product feedback link — form, Discord invite, or GitHub Discussions (shown in Settings → Privacy when set)
# VITE_BETA_FEEDBACK_URL=https://discord.gg/xxxxxxxx
