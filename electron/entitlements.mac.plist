<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Voice assistant + double-clap wake -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Local network: Ollama + Python backend on 127.0.0.1 -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- User-selected files (sort, attachments) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Desktop automation: AppleScript / System Events for app focus, window
         control, and the desktop-control tools (gated behind user consent). -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <!-- Allow the spawned PyInstaller backend child (control_computer, OCR) to
         run under the hardened runtime without being killed by code-signing. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
  </dict>
</plist>
