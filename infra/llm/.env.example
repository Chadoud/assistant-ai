# Copy to .env — never commit .env

DOMAIN=llm-staging.exosites.ch
ACME_EMAIL=ops@exosites.ch

# LiteLLM admin + virtual key provisioning
LITELLM_MASTER_KEY=sk-change-me-master

# Exo backend service keys (create in LiteLLM after first deploy)
EXO_BACKEND_STAGING_KEY=sk-exo-staging
EXO_BACKEND_PROD_KEY=sk-exo-prod

# GA capacity target: 5 concurrent cloud sorters on this VPS (see docs/CAPACITY_BASELINE.md)
SORT_CAPACITY_TARGET_USERS=5

# Ollama tuning (chat GPU instance) — 2 parallel keeps 5-user queue stable on 18GB RAM
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_QUEUE=64
OLLAMA_KEEP_ALIVE=30m
# Optional: separate embed instance tuning (split-embed overlay)
OLLAMA_EMBED_NUM_PARALLEL=4
OLLAMA_EMBED_MAX_QUEUE=32

# Per-user analyze rows when cloud credentials sync (VPS broker default 1)
SORT_CLOUD_SORT_CONCURRENCY=1

# cloud = LLM-only on VPS; cloud_full = upload files to sort-worker (OCR + classify on VPS)
# SORT_SERVICE_MODE=cloud
# Optional: bump to invalidate desktop config cache without other env changes
# SORT_CREDENTIALS_CONFIG_REVISION_SALT=

# Optional Redis fair queue — recommended for 5+ concurrent users (staging: enabled)
SORT_LLM_QUEUE_ENABLED=1
# auto = direct LiteLLM when idle, queue_url in credentials only under load
SORT_LLM_QUEUE_IN_CREDENTIALS=auto
SORT_QUEUE_ADMIT_THRESHOLD=2
SORT_QUEUE_INTERNAL_URL=http://sort-queue:4011
SORT_QUEUE_WORKERS=4
SORT_QUEUE_PENDING_ALERT_THRESHOLD=32
SORT_QUEUE_WAIT_MS=600000

# Optional Prometheus (localhost:9090 on VPS — queue + LiteLLM metrics)
# SORT_PROMETHEUS_ENABLED=1
# Optional Alertmanager (pair with Prometheus; set webhook in alertmanager.yml)
# SORT_ALERTMANAGER_ENABLED=1
LLM_BASE_URL=
