# Copy to cloud-node/.env.deploy (gitignored)

# ── api.exosites.ch (Node.js) — used by scripts/deploy-cloud-api.sh ──────────
SSH_USER=your_node_ssh_user
SSH_HOST=your-node-host.ssh.hosting-ik.com
# SSH_PASSWORD=

# Infomaniak Manager → api.exosites.ch → chemin absolu
REMOTE_PATH=./sites/api.exosites.ch

# Set to 1 if remote has no npm/ssh restart — upload only; restart via Infomaniak panel
# SKIP_REMOTE_NPM=1

# ── exosites.ch Web (marketing site) — desktop installers ───────────────────
# Same SSH account as exosites-agency (.env: SSH_USER / SSH_HOST / SSH_PASSWORD).
# NOT the api.exosites.ch Node host — downloads live under the Web docroot.
DOWNLOADS_SSH_USER=your_web_ssh_user
DOWNLOADS_SSH_HOST=your-web-host.ftp.infomaniak.com
# DOWNLOADS_SSH_PASSWORD=

# Infomaniak Manager → exosites.ch → chemin absolu → downloads/ai-file-manager
# Public URL: https://exosites.ch/downloads/ai-file-manager/
# GitHub secrets EXOSITES_DEPLOY_SSH_* + EXOSITES_DOWNLOADS_PATH use these Web credentials.
DOWNLOADS_REMOTE_PATH=./sites/exosites.ch/downloads/ai-file-manager

# Set to 1 to push cloud-node/.env to the server after rsync (default: skip — use Infomaniak panel)
# UPLOAD_ENV=1

# Set to 1 to run verify-cloud-auth-api.sh after deploy (requires Node restart first)
# VERIFY_AFTER_DEPLOY=1
