# Optional credentials for GA verify scripts (login — not rate-limited like register).
# Copy to .env.verify and set a dedicated smoke-test account on api.exosites.ch.
#
#   cp cloud-node/.env.verify.example cloud-node/.env.verify
#   ./scripts/ga-provision-verify-account.sh
#
GA_VERIFY_EMAIL=ga-verify@exosites.ch
GA_VERIFY_PASSWORD=
