# DataSuite — PHP 8.4 read-only dashboard (datasuite.exosites.ch)
# Copy to .env on Infomaniak (outside web root or panel env vars). Never commit .env.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=YOUR_IK_ID_exo_app
DB_USER=YOUR_IK_ID_datasuite
DB_PASSWORD=

# Generate: php -r "echo password_hash('your-team-password', PASSWORD_DEFAULT), PHP_EOL;"
ADMIN_PASSWORD_HASH=

SESSION_NAME=datasuite_session
