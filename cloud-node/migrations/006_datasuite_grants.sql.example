-- Substitute YOUR_IK_ID_* placeholders with your Infomaniak account prefix before running.
-- Run in phpMyAdmin as Infomaniak database ADMIN (not YOUR_IK_ID_db_admin).
-- Prerequisite: create user YOUR_IK_ID_datasuite in Manager → Bases de données → Utilisateurs
-- with password matching datasuite/.env.db (MariaDB user — separate from FTP deploy user YOUR_IK_ID_datasuite_ro).

-- If admin SQL console allows CREATE USER (optional — panel may already create the user):
-- CREATE USER IF NOT EXISTS 'YOUR_IK_ID_datasuite'@'%' IDENTIFIED BY 'YOUR_PASSWORD';
-- CREATE USER IF NOT EXISTS 'YOUR_IK_ID_datasuite'@'localhost' IDENTIFIED BY 'YOUR_PASSWORD';

