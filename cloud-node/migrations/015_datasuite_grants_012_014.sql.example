-- Run in phpMyAdmin as Infomaniak database ADMIN (not YOUR_IK_ID_db_admin).
-- Adds DataSuite read access for migrations 012–014 + triage write on crash_triage.
-- Prerequisite: migrations 012, 013, 014 applied (npm run deploy:cloud-api).

-- Crash inbox + enriched crash_reports columns (012)
GRANT SELECT ON `YOUR_IK_ID_exo_app`.`v_crash_inbox_30d` TO 'YOUR_IK_ID_datasuite'@'%';
GRANT SELECT ON `YOUR_IK_ID_exo_app`.`v_crash_inbox_30d` TO 'YOUR_IK_ID_datasuite'@'localhost';

